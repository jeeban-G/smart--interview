# AI Provider Selection
# Options: 'openclaw' (default) or 'minimax'
AI_PROVIDER=openclaw

# OpenClaw Configuration (when AI_PROVIDER=openclaw)
# Get your OpenClaw API from your local deployment
# Default OpenClaw Gateway runs on localhost:18789
OPENCLAW_API_KEY=openclaw
OPENCLAW_API_URL=http://localhost:18789/v1/chat/completions
OPENCLAW_MODEL=deepseek-chat

# MiniMax API Configuration (when AI_PROVIDER=minimax)
# Get your API key from https://platform.minimaxi.com
MINIMAX_API_KEY=your_api_key_here

# JWT Secret (generate a strong random string in production)
JWT_SECRET=your_jwt_secret_here
